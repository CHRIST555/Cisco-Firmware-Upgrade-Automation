# =============================================================================
# .gitignore — Cisco IOS-XE Firmware Upgrade Automation
# =============================================================================

# Never commit firmware binaries to the repo
# Drop your .bin file in the project root — it will be found automatically
*.bin
*.tar
*.pkg

# Config backups and reports (potentially sensitive)
backups/
reports/

# Ansible temp files
*.retry
/tmp/ansible_inv_*

# Vault password files
*.vp
.vault_pass
vault_pass.txt

# Python
__pycache__/
*.pyc
*.pyo
.env
venv/
.venv/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo
